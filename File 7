name: Weekly update

on:
  workflow_dispatch: {}
  schedule:
    # Weekly on Sundays at 12:00 UTC (keeps it stable across DST)
    - cron: "0 12 * * 0"

permissions:
  contents: write

jobs:
  run:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"

      - name: Install deps
        run: npm ci

      - name: Run updater
        env:
          DEEPL_API_KEY: ${{ secrets.DEEPL_API_KEY }}
        run: node update.js

      - name: Commit updated data
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add site/data/entries.json
          git commit -m "Update entries.json" || echo "No changes to commit"
          git push
